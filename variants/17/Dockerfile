# GENERATED by scripts/render-dockerfiles.sh — DO NOT EDIT.
# Edit Dockerfile.template + manifest.json, then re-run the script.
FROM postgres:17-alpine@sha256:dc17045ccfd343b49600570ea734b9c4991cf1c3f3302e67df51e3b402dd55c4

# Overridable at build time: `--build-arg PGVECTOR_VERSION=x.y.z`. Defaults to
# the value baked in by render-dockerfiles.sh from manifest.json.
ARG PGVECTOR_VERSION=0.8.3

LABEL org.opencontainers.image.source="https://github.com/jonathanmcohen/pgvector"
LABEL org.opencontainers.image.title="postgres-17-pgvector"
LABEL org.opencontainers.image.description="Postgres 17 alpine with pgvector ${PGVECTOR_VERSION}"
LABEL org.opencontainers.image.licenses="MIT"
LABEL com.jonco.pgvector.version="${PGVECTOR_VERSION}"
LABEL com.jonco.postgres.major="17"

# Build pgvector from source against this exact Postgres.
#
# Build deps are intentionally version-agnostic: `clang` + `llvm-dev` resolve to
# the toolchain shipped in the SAME Alpine release the postgres base was built
# against, so the LLVM bitcode pgvector emits for JIT inlining matches the
# server's llvmjit. Pinning clang15/llvm15 (as in older recipes) breaks on
# current Alpine. All build deps are dropped afterward to keep the image lean.
RUN set -eux; \
    apk add --no-cache --virtual .build-deps \
        build-base \
        clang \
        llvm-dev \
        git; \
    git clone --depth 1 --branch "v${PGVECTOR_VERSION}" \
        https://github.com/pgvector/pgvector.git /tmp/pgvector; \
    cd /tmp/pgvector; \
    make OPTFLAGS=""; \
    make install; \
    cd /; \
    rm -rf /tmp/pgvector; \
    apk del .build-deps
